# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Server
PORT=3000
NODE_ENV=development

# Bot timeouts (in minutes)
BOT_REMINDER_TIMEOUT_MIN=10
BOT_CLOSE_TIMEOUT_MIN=40

# External APIs
CNPJ_API_URL=https://brasilapi.com.br/api/cnpj/v1

# ─── Banco de Dados (opcional) ───────────────────────────────────────────────
# Deixe vazio para desativar persistência. O bot funciona normalmente sem banco.
DATABASE_URL=postgresql://essencial:essencial@localhost:5432/essencial_bot

# Redis (opcional — deixe vazio para usar session store em memória)
REDIS_URL=

# Logging
LOG_LEVEL=info

# ─── RD Station Marketing (opcional) ─────────────────────────────────────────
# Integração automática: ao finalizar o fluxo, o lead é enviado ao RD Station.
# Deixe RD_ENABLED=false (ou vazio) para desativar sem remover as variáveis.
RD_API_KEY=                          # API Key do RD Station Marketing
RD_API_URL=https://api.rd.services   # URL base da API (não inclui /platform)
RD_ENABLED=false                     # true para ativar envio ao RD Station
