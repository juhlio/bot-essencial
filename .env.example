# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Server
PORT=3000
NODE_ENV=development

# Bot timeouts (in minutes)
BOT_REMINDER_TIMEOUT_MIN=10
BOT_CLOSE_TIMEOUT_MIN=40

# External APIs
CNPJ_API_URL=https://brasilapi.com.br/api/cnpj/v1

# ─── Banco de Dados (opcional) ───────────────────────────────────────────────
# Deixe vazio para desativar persistência. O bot funciona normalmente sem banco.
DATABASE_URL=postgresql://essencial:essencial@localhost:5432/essencial_bot

# Redis (opcional — deixe vazio para usar session store em memória)
REDIS_URL=

# Logging
LOG_LEVEL=info

# ─── Autenticação JWT ────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=                                      # obrigatório em produção

# ─── RD Station Marketing (Conversão via API Key) ────────────────────────────
RD_STATION_ENABLED=false                         # true para ativar envio ao RD Station
RD_STATION_API_KEY=                              # API Key (gerar em App Publisher)
RD_STATION_CONVERSION_ID=whatsapp-bot-essencial  # Identificador da conversão
